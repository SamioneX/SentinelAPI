# SentinelAPI Environment Reference
#
# This file is the canonical config contract for SentinelAPI and InfraKit integration.
# Required values are intentionally left blank.
# Profile templates in env/.env.* should only override profile-dependent settings.

# =========================================================
# Core App
# =========================================================
APP_NAME=SentinelAPI
ENVIRONMENT=local
APP_PROFILE=cost-optimized
LOG_LEVEL=INFO

# =========================================================
# REQUIRED: Upstream Backend
# SentinelAPI proxies requests to this base URL.
# Example: https://api.myapp.com
# =========================================================
UPSTREAM_BASE_URL=
REQUEST_TIMEOUT_SECONDS=10

# =========================================================
# REQUIRED: JWT Verification
# Configure ONE verification approach:
# 1) Shared secret/static key mode:
#    - JWT_SECRET_KEY (HS algorithms), or JWT_PUBLIC_KEY
# 2) OIDC/JWKS mode:
#    - JWT_JWKS_URL (+ optional JWT_ISSUER and JWT_AUDIENCE)
# =========================================================
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URL=
JWT_JWKS_CACHE_TTL_SECONDS=300
JWT_SECRET_KEY=
JWT_PUBLIC_KEY=

# =========================================================
# Runtime Backends
# Defaults here are cost-optimized oriented and can be overridden by profile templates.
# =========================================================
RATE_LIMIT_BACKEND=memory
REQUEST_LOG_BACKEND=stdout

# =========================================================
# Rate Limiting
# =========================================================
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_RATE=1.0
BLOCKLIST_PREFIX=sentinel:blocklist

# =========================================================
# AWS Data/Alerting
# =========================================================
AWS_REGION=us-west-2
DDB_TABLE_NAME=sentinel-request-logs
DDB_AGGREGATE_TABLE_NAME=sentinel-traffic-agg
DDB_RATE_LIMIT_TABLE_NAME=sentinel-rate-limits
DDB_BLOCKLIST_TABLE_NAME=sentinel-blocklist
SNS_TOPIC_ARN=

# =========================================================
# Anomaly Detection
# =========================================================
ANOMALY_AUTO_BLOCK=true
ANOMALY_AUTO_BLOCK_TTL_SECONDS=3600
ANOMALY_THRESHOLD=8.0
ANOMALY_MIN_REQUESTS=40
