APP_NAME=SentinelAPI
ENVIRONMENT=local
APP_PROFILE=cost-optimized
LOG_LEVEL=INFO

UPSTREAM_BASE_URL=http://host.docker.internal:9000
REQUEST_TIMEOUT_SECONDS=10

JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_SECRET_KEY=change-me
JWT_PUBLIC_KEY=

# Backends:
# - cost-optimized defaults: RATE_LIMIT_BACKEND=memory, REQUEST_LOG_BACKEND=stdout
# - production-grade defaults: RATE_LIMIT_BACKEND=redis, REQUEST_LOG_BACKEND=dynamodb
RATE_LIMIT_BACKEND=
REQUEST_LOG_BACKEND=

REDIS_URL=redis://redis:6379/0
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_RATE=1.0
BLOCKLIST_PREFIX=sentinel:blocklist

AWS_REGION=us-west-2
DDB_TABLE_NAME=sentinel-request-logs
DDB_AGGREGATE_TABLE_NAME=sentinel-traffic-agg
DDB_RATE_LIMIT_TABLE_NAME=sentinel-rate-limits
DDB_BLOCKLIST_TABLE_NAME=sentinel-blocklist
SNS_TOPIC_ARN=

ANOMALY_AUTO_BLOCK=true
ANOMALY_AUTO_BLOCK_TTL_SECONDS=3600
ANOMALY_THRESHOLD=8.0
ANOMALY_MIN_REQUESTS=50
