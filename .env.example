# =========================================================
# REQUIRED INPUT
# =========================================================
# Upstream service base URL to protect with SentinelAPI.
# Example: https://abcde.lambda-url.us-east-1.on.aws
SENTINEL_API_UPSTREAM_BASE_URL=

# Auth method selection is required.
# Please set ONE of the options below by uncommenting and providing a value.

# Option A (HS256/HS384/HS512): shared secret signing/verification.
# SENTINEL_API_JWT_SECRET_KEY=

# Option B (RS*/ES*): static public key verification.
# SENTINEL_API_JWT_PUBLIC_KEY=

# Option C (recommended for production): OIDC/JWKS endpoint URL.
# SENTINEL_API_JWT_JWKS_URL=

# =========================================================
# OPTIONAL: OPTIMIZATION TARGET
# =========================================================
# Preset defaults are selected from code.
# Allowed values: cost, performance
# If omitted, defaults to cost.
# SENTINEL_API_OPTIMIZE_FOR=cost

# =========================================================
# OPTIONAL: EXPLICIT KNOB OVERRIDES
# =========================================================
# Any knob set here overrides the selected preset value.

# Infrastructure sizing knobs (SDK deploy-time)
# SENTINEL_API_FARGATE_CPU=256
# SENTINEL_API_FARGATE_MEMORY_MIB=512
# SENTINEL_API_ECS_DESIRED_COUNT=1
# SENTINEL_API_LOG_RETENTION_DAYS=7

# Gateway runtime knobs
# SENTINEL_API_LOG_LEVEL=INFO
# SENTINEL_API_REQUEST_TIMEOUT_SECONDS=10
# SENTINEL_API_RATE_LIMIT_CAPACITY=100
# SENTINEL_API_RATE_LIMIT_REFILL_RATE=1.0
# Optional: use prebuilt public gateway image (default points to official SentinelAPI ECR Public repo).
# Override repository/tag if you run your own release pipeline.
# SENTINEL_API_GATEWAY_IMAGE_REPOSITORY=public.ecr.aws/n6a2e6z3/sentinel-api-gateway
# SENTINEL_API_GATEWAY_IMAGE_TAG=
# Optional: set true to force local Docker build+push instead of prebuilt image usage.
# SENTINEL_API_BUILD_GATEWAY_IMAGE=false

# Anomaly detector knobs
# SENTINEL_API_ANOMALY_THRESHOLD=8.0
# SENTINEL_API_ANOMALY_MIN_REQUESTS=40
# SENTINEL_API_ANOMALY_AUTO_BLOCK=true
# SENTINEL_API_ANOMALY_AUTO_BLOCK_TTL_SECONDS=3600

# JWT verification knobs
# SENTINEL_API_JWT_ALGORITHM=HS256
# SENTINEL_API_JWT_ISSUER=
# SENTINEL_API_JWT_AUDIENCE=
# SENTINEL_API_JWT_JWKS_CACHE_TTL_SECONDS=300

# =========================================================
# AUTO-MANAGED BY SDK STACK DEPLOYMENT (DO NOT SET MANUALLY)
# =========================================================
# SENTINEL_API_DDB_TABLE_NAME
# SENTINEL_API_DDB_AGGREGATE_TABLE_NAME
# SENTINEL_API_DDB_RATE_LIMIT_TABLE_NAME
# SENTINEL_API_DDB_BLOCKLIST_TABLE_NAME
# SENTINEL_API_SNS_TOPIC_ARN
# SENTINEL_API_REDIS_URL
# SENTINEL_API_AWS_REGION
